<?xml version="1.0" encoding="utf-8" ?>
<Application xmlns="http://xamarin.com/schemas/2014/forms"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="daily_app.App">
    <Application.Resources>
        <ResourceDictionary>
            <Style Class="Body" TargetType="Grid">
                <Setter Property="BackgroundColor" Value="#755C80"/>
            </Style>
            <Style Class="BtnAdd" TargetType="Button">
                <Setter Property="BorderColor" Value="#503E57"/>
                <Setter Property="BorderWidth" Value="3"/>
                <Setter Property="BackgroundColor" Value="#9B79A8"/>
                <Setter Property="TextColor" Value="#F0EBF2"/>
            </Style>
            <Style Class="HabitCard" TargetType="StackLayout">
                <Setter Property="BackgroundColor" Value="#9B79A8"/>
            </Style>
            <Style Class="HabitCardFrame" TargetType="Frame">
                <Setter Property="OutlineColor" Value="#503E57"/>
                <Setter Property="Padding" Value="3"/>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>